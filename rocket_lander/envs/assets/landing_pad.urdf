<?xml version="1.0"?>
<robot name="landing_pad">
  <material name="target_red">
    <color rgba="0.8 0.1 0.1 0.8"/>
  </material>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="2.5" length="0.1"/>
      </geometry>
      <material name="target_red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="2.5" length="0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="1000.0"/>
      <inertia ixx="100" ixy="0" ixz="0" iyy="100" iyz="0" izz="100"/>
    </inertial>
  </link>
</robot>
